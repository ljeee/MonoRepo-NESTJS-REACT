# ── Postgres ─────────────────────────────────────────────────
DB_PASSWORD=your_secure_db_password_here     # Cambiar en producción

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_32_character_jwt_secret_here
JWT_EXPIRES_IN=28800    # 8 horas en segundos

# ── CORS (ajustar con la IP real del servidor en LAN) ────────
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:1420,http://localhost:5173,tauri://localhost,http://tauri.localhost,https://tauri.localhost,http://[IP_ADDRESS],https://pos.tu-dominio.com,https://api.tu-dominio.com,*

# ── Cloudflare Tunnel (Token) ────────────────────────────────
# Pega aquí el token "eyJh..." que te da Cloudflare Zero Trust:
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ── Mail Service (Gmail App Password) ─────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=tu-correo@gmail.com
MAIL_PASS=tu-token-de-app-google
REPORT_EMAIL=destinatario-reportes@correo.com


# ── Perfil del Negocio ─────────────────────────────────────────
COMPANY_NIT=900.000.000-1
COMPANY_NAME=Nombre del Negocio
COMPANY_ADDRESS=Calle 123 #45-67
COMPANY_PHONE=3001234567
COMPANY_TAX_REGIMEN=Régimen Simple
COMPANY_TAX_PERCENT=0