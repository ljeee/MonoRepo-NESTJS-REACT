# ── Postgres ─────────────────────────────────────────────────
DB_PASSWORD=your_secure_db_password_here     # Cambiar en producción

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_32_character_jwt_secret_here
JWT_EXPIRES_IN=28800    # 8 horas en segundos

# ── CORS (ajustar con la IP real del servidor en LAN) ────────
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:1420,http://localhost:5173,tauri://localhost,http://tauri.localhost,https://tauri.localho00,https://pos.tu-dominio.com,https://api.tu-dominio.com,*

# ── Cloudflare Tunnel (Token) ────────────────────────────────
# Pega aquí el token "eyJh..." que te da Cloudflare Zero Trust:
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here
