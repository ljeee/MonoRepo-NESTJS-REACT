{
  "name": "monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*",
    "Frontend",
    "Desktop",
    "Backend"
  ],
  "scripts": {
    "backend": "npm run start:dev --prefix Backend",
    "backend:docker": "copy Backend\\.env.docker Backend\\.env && npm run start:dev --prefix Backend",
    "backend:local": "copy Backend\\.env.local Backend\\.env && npm run start:dev --prefix Backend",
    "backend:prod": "npm run start:prod --prefix Backend",
    "frontend": "npm run start --prefix Frontend",
    "frontend:web": "npm run web --prefix Frontend",
    "dev": "concurrently \"npm run start:dev --prefix Backend\" \"npm run web --prefix Frontend\"",
    "dev:docker": "npm run db:up && npm run backend:docker",
    "dev:local": "npm run backend:local",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down --volumes --remove-orphans"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "concurrently": "^9.0.0",
    "expo": "~55.0.25",
    "lightningcss": "1.30.1"
  },
  "overrides": {
    "lightningcss": "1.30.1",
    "semver": "^7.5.3",
    "ajv": "^8.17.1",
    "path-to-regexp": "^8.3.0",
    "tar": "^7.5.11",
    "picomatch": "^4.0.4"
  }
}
