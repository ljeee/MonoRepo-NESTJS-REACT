# ── PostgreSQL Local (puerto 5432) ─────────────────────────
# Usa "localhost" si corres NestJS directo en tu PC sin Docker
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_database_password_here
DATABASE_NAME=your_database_name_here

# ── Redis ──────────────────────────────────────────────────────
# Configuracion si tienes un Redis corriendo local o en la nube
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT Auth ───────────────────────────────────────────────────
JWT_SECRET=your_32_character_jwt_secret_here
JWT_EXPIRES_IN=28800

# ── Server Options ─────────────────────────────────────────────
PORT=3000
HOST=localhost
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────────
# Origenes permitidos separados por comas
CORS_ORIGINS=http://localhost:8081,http://localhost:1420,http://localhost:5173,tauri://localhost,http://tauri.localhost,https://tauri.localhost,*
# ── Mail Service (Gmail App Password) ─────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=tu-correo@gmail.com
MAIL_PASS=tu-token-de-app-google
REPORT_EMAIL=destinatario-reportes@correo.com

# ── Cloudflare Tunnel (Token) ────────────────────────────────
# Pega aquí el token "eyJh..." que te da Cloudflare Zero Trust:
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ── Perfil del Negocio ─────────────────────────────────────────
COMPANY_NIT=900.000.000-1
COMPANY_NAME=Nombre del Negocio
COMPANY_ADDRESS=Calle 123 #45-67
COMPANY_PHONE=300142141
COMPANY_TAX_REGIMEN=Régimen Simple
COMPANY_TAX_PERCENT=0
